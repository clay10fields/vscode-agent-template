# Copy to .env and fill in. setup.sh prompts for these.

# Required - the brains
OPENROUTER_API_KEY=

# Optional - GitHub MCP for repo ops
GITHUB_TOKEN=

# Optional - Anthropic direct (Cline can use Anthropic native if you prefer)
ANTHROPIC_API_KEY=

# LiteLLM proxy port - leave default unless conflict
LITELLM_PORT=4000

# Ollama host - leave default unless remote
OLLAMA_HOST=http://localhost:11434

# Trading Journal vault (only used by neurotrader profile)
JOURNAL_VAULT_PATH=$HOME/Documents/NeuroTrader-Journal

# NeuroTrader DB path (only used by neurotrader profile)
NEUROTRADER_DB_PATH=$HOME/Documents/GitHub/neuro-trade-bot/data/neurotrader.db

# Optional - Qdrant for semantic trade search (off by default)
QDRANT_URL=
QDRANT_API_KEY=
